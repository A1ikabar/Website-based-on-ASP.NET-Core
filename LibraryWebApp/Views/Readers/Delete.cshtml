@model LibraryWebApp.Models.Reader

@{
    ViewData["Title"] = "Delete Reader";
}

<h2>Delete Reader</h2>

<p class="text-danger">Are you sure you want to delete this reader?</p>

<dl class="row">
    <dt class="col-sm-2">Full Name</dt>
    <dd class="col-sm-10">@Model.FullName</dd>

    <dt class="col-sm-2">Library Card</dt>
    <dd class="col-sm-10">@Model.LibraryCardNumber</dd>

    <dt class="col-sm-2">Phone</dt>
    <dd class="col-sm-10">@Model.PhoneNumber</dd>
</dl>

<form asp-action="Delete" method="post">
    <input type="hidden" asp-for="Id" />
    <button type="submit" class="btn btn-danger">Delete</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>