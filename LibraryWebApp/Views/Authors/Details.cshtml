@model LibraryWebApp.Models.Author

@{
    ViewData["Title"] = "Author Details";
}

<h2>Author Details</h2>

<dl class="row">
    <dt class="col-sm-2">Full Name</dt>
    <dd class="col-sm-10">@Model.FullName</dd>

    <dt class="col-sm-2">Country</dt>
    <dd class="col-sm-10">@(Model.Country ?? "—")</dd>
</dl>

<h4 class="mt-4">Books by this author</h4>

@if (Model.Books != null && Model.Books.Any())
{
    <ul>
        @foreach (var book in Model.Books)
        {
            <li>@book.Title (@book.PublicationYear) - @book.Genre</li>
        }
    </ul>
}
else
{
    <p>No books found for this author.</p>
}

<p class="mt-3">
    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">Edit</a>
    <a asp-action="Index" class="btn btn-secondary">Back</a>
</p>