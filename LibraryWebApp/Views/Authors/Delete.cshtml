@model LibraryWebApp.Models.Author

@{
    ViewData["Title"] = "Delete Author";
}

<h2>Delete Author</h2>

<p class="text-danger">Are you sure you want to delete this author?</p>

<dl class="row">
    <dt class="col-sm-2">Full Name</dt>
    <dd class="col-sm-10">@Model.FullName</dd>

    <dt class="col-sm-2">Country</dt>
    <dd class="col-sm-10">@(Model.Country ?? "—")</dd>
</dl>

@if (Model.Books != null && Model.Books.Any())
{
    <div class="alert alert-warning">
        <strong>Warning:</strong> This author has @Model.Books.Count() book(s). Deleting this author will also delete all their books.
    </div>
}

<form asp-action="Delete" method="post">
    <input type="hidden" asp-for="Id" />
    <button type="submit" class="btn btn-danger">Delete</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>