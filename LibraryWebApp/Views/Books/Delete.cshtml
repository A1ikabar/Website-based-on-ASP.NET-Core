@model LibraryWebApp.Models.Book

@{
    ViewData["Title"] = "Delete Book";
}

<h2>Delete Book</h2>

<p class="text-danger">Are you sure you want to delete this book?</p>

<dl class="row">
    <dt class="col-sm-2">Title</dt>
    <dd class="col-sm-10">@Model.Title</dd>

    <dt class="col-sm-2">Author</dt>
    <dd class="col-sm-10">@(Model.Author?.FullName ?? "—")</dd>

    <dt class="col-sm-2">Genre</dt>
    <dd class="col-sm-10">@Model.Genre</dd>

    <dt class="col-sm-2">Publication Year</dt>
    <dd class="col-sm-10">@Model.PublicationYear</dd>
</dl>

@if (Model.Borrowings != null && Model.Borrowings.Any(b => b.ReturnedAt == null))
{
    <div class="alert alert-warning">
        <strong>Warning:</strong> This book is currently borrowed and cannot be deleted until it is returned.
    </div>
    <a asp-action="Index" class="btn btn-secondary">Back</a>
}
else
{
    <form asp-action="Delete" method="post">
        <input type="hidden" asp-for="Id" />
        <button type="submit" class="btn btn-danger">Delete</button>
        <a asp-action="Index" class="btn btn-secondary">Cancel</a>
    </form>
}