@model LibraryWebApp.Models.Review

@{
    ViewData["Title"] = "Delete Review";
}

<h2>Delete Review</h2>

<p class="text-danger">Are you sure you want to delete this review?</p>

<dl class="row">
    <dt class="col-sm-2">Book</dt>
    <dd class="col-sm-10">@(Model.Book?.Title ?? "—")</dd>

    <dt class="col-sm-2">Reader</dt>
    <dd class="col-sm-10">@(Model.Reader?.FullName ?? "—")</dd>

    <dt class="col-sm-2">Rating</dt>
    <dd class="col-sm-10">@Model.Rating ★</dd>

    <dt class="col-sm-2">Date</dt>
    <dd class="col-sm-10">@Model.ReviewDate.ToShortDateString()</dd>

    <dt class="col-sm-2">Comment</dt>
    <dd class="col-sm-10">@(Model.Comment ?? "No comment")</dd>
</dl>

<form asp-action="Delete" method="post">
    <input type="hidden" asp-for="Id" />
    <button type="submit" class="btn btn-danger">Delete</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>