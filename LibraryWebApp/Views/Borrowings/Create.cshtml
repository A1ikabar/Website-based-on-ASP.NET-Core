@model LibraryWebApp.Models.Borrowing

@{
    ViewData["Title"] = "Create Borrowing";
}

<h2>Create Borrowing</h2>

<form asp-action="Create" method="post">
    <div class="mb-3">
        <label asp-for="ReaderId" class="form-label">Reader</label>
        <select asp-for="ReaderId" asp-items="ViewBag.ReaderId" class="form-select">
            <option value="">-- Select Reader --</option>
        </select>
        <span asp-validation-for="ReaderId" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="BookId" class="form-label">Book</label>
        <select asp-for="BookId" asp-items="ViewBag.BookId" class="form-select">
            <option value="">-- Select Book --</option>
        </select>
        <span asp-validation-for="BookId" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="BorrowedAt" class="form-label"></label>
        <input asp-for="BorrowedAt" class="form-control" type="date" />
        <span asp-validation-for="BorrowedAt" class="text-danger"></span>
    </div>

    <button type="submit" class="btn btn-success">Save</button>
    <a asp-action="Index" class="btn btn-secondary">Back</a>
</form>