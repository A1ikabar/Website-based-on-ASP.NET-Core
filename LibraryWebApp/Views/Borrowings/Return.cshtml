@model LibraryWebApp.Models.Borrowing

@{
    ViewData["Title"] = "Return Book";
}

<h2>Return Book</h2>

<div class="alert alert-info">
    <p>Confirm that the book is being returned.</p>
</div>

<dl class="row">
    <dt class="col-sm-2">Reader</dt>
    <dd class="col-sm-10">@(Model.Reader?.FullName ?? "—")</dd>

    <dt class="col-sm-2">Book</dt>
    <dd class="col-sm-10">@(Model.Book?.Title ?? "—")</dd>

    <dt class="col-sm-2">Borrowed Date</dt>
    <dd class="col-sm-10">@Model.BorrowedAt.ToShortDateString()</dd>
</dl>

<form asp-action="ReturnConfirmed" method="post">
    <input type="hidden" name="readerId" value="@Model.ReaderId" />
    <input type="hidden" name="bookId" value="@Model.BookId" />
    <button type="submit" class="btn btn-success">Confirm Return</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>