@model LibraryWebApp.Models.Borrowing

@{
    ViewData["Title"] = "Delete Borrowing";
}

<h2>Delete Borrowing</h2>

<p class="text-danger">Are you sure you want to delete this borrowing record?</p>

<dl class="row">
    <dt class="col-sm-2">Reader</dt>
    <dd class="col-sm-10">@(Model.Reader?.FullName ?? "—")</dd>

    <dt class="col-sm-2">Book</dt>
    <dd class="col-sm-10">@(Model.Book?.Title ?? "—")</dd>

    <dt class="col-sm-2">Borrowed Date</dt>
    <dd class="col-sm-10">@Model.BorrowedAt.ToShortDateString()</dd>

    <dt class="col-sm-2">Returned Date</dt>
    <dd class="col-sm-10">@(Model.ReturnedAt?.ToShortDateString() ?? "Not returned")</dd>
</dl>

<form asp-action="Delete" method="post">
    <input type="hidden" asp-for="ReaderId" />
    <input type="hidden" asp-for="BookId" />
    <button type="submit" class="btn btn-danger">Delete</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>